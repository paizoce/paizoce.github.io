---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import OfficerCard from "../components/OfficerCard.astro";
import FeatureCard from "../components/FeatureCard.astro";
import UpcomingEvent from "../components/UpcomingEvent.astro";
---

<BaseLayout title="Paizo | Independence High School">
  <Header />

  <section class="membership-header" style="margin-top: 80px;">
    <h1 class="membership-title">Independence High School Chapter</h1>
    <p><b>Our Founding Chapter</b></p>
  </section>

  <section
    style="padding: 3rem 1rem; max-width: 900px; margin: auto; text-align: center;"
  >
    <h2
      style="color: var(--accent-color); font-size: 2.5rem; margin-bottom: 1rem; font-weight: bold;"
    >
      About Our Chapter
    </h2>
    <p style="font-size: 1.2rem; color: #fff; line-height: 1.6;">
      The Independence High School chapter is the founding chapter of the Paizo
      Chamber Ensemble. Established by passionate student musicians, this
      chapter has been instrumental in building our community and spreading the
      love of chamber music.
    </p>
    <p
      style="font-size: 1.2rem; color: #fff; line-height: 1.6; margin-top: 1rem;"
    >
      Our members come from diverse musical backgrounds and are united by their
      passion for performing, teaching, and sharing music with the community.
    </p>

    <!-- Chapter Officers Section -->
    <section
      style="background-color: var(--main-color); padding: 4rem 2rem; text-align: center; margin: 3rem 0;"
    >
      <h2
        style="color: var(--accent-color); font-size: 2.5rem; margin-bottom: 2rem; font-weight: bold;"
      >
        Chapter Officers
      </h2>
      <div
        style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; max-width: 1000px; margin: auto;"
      >
        <OfficerCard
          name="Aditya Pradhan"
          role="Chapter President"
          img="/images/officers/aditya_pradhan.jpg"
        />
        <OfficerCard
          name="Vaghul Srivallaban"
          role="Chapter Vice President"
          img="/images/officers/vaghul.jpg"
        />
        <OfficerCard
          name="Eshaan Nallapareddy"
          role="Chapter Secretary"
          img="/images/officers/eshaan.png"
        />
        <OfficerCard
          name="Aditya Rao Udupi"
          role="Membership Officer"
          img="/images/officers/aditya_rao_udupi.jpg"
        />
        <OfficerCard
          name="Sriram Alla"
          role="Membership Officer"
          img="/images/officers/sriram.jpg"
        />
        <OfficerCard
          name="Anikait Rana"
          role="Outreach Officer"
          img="/images/officers/anikait.jpg"
        />
        <OfficerCard
          name="Ajay Aravanan"
          role="Logistics Officer"
          img="/images/officers/ajay.jpg"
        />
        <OfficerCard
          name="Saswati Parthibban"
          role="Tutoring Officer"
          img="/images/officers/sash.jpg"
        />
        <OfficerCard
          name="Sidharth Iyer"
          role="Publicity Officer"
          img="/images/officers/sid.jpg"
        />
      </div>
    </section>

    <!-- Upcoming Events Section -->
    <section
      style="background-color: var(--footer-bg); padding: 4rem 2rem; text-align: center;"
    >
      <h2
        style="color: var(--accent-color); font-size: 2.5rem; margin-bottom: 2rem; font-weight: bold;"
      >
        Upcoming Events
      </h2>
      <div
        style="display: grid; gap: 1.25rem; max-width: 1000px; margin: auto;"
      >
        <UpcomingEvent
          title="Pioneer Ridge Gracious Retirement Living"
          description="Join us as Paizo performs a warm selection of holiday favorites to bring cheer to the residents. We'll play a short, festive program designed for a cozy, engaging afternoon of seasonal music."
          date="December 13, 2025"
          time="4:00 PM - 5:00 PM"
          location="7210 Linkside Point Dr, McKinney, TX 75071"
          image="/images/gigs/pioneer_ridge.png"
        />

        <UpcomingEvent
          title="Hidden Springs of McKinney"
          description="Paizo will present an intimate holiday set featuring familiar carols and instrumental arrangements intended to delight residents and families, fostering community spirit and smiles."
          date="December 14, 2025"
          time="2:00 PM - 3:00 PM"
          location="6421 McKinney Ranch Pkwy, McKinney, TX 75070"
          image="/images/gigs/hidden_springs.png"
        />
      </div>
    </section>

    <!-- Tutoring Program Highlight -->
    <section
      style="background-color: var(--main-color); padding: 4rem 2rem; text-align: center;"
    >
      <h2
        style="color: var(--accent-color); font-size: 2.5rem; margin-bottom: 1.5rem; font-weight: bold;"
      >
        Free Tutoring Available!
      </h2>
      <p
        style="font-size: 1.2rem; color: #fff; line-height: 1.6; margin-bottom: 2rem; max-width: 800px; margin-left: auto; margin-right: auto;"
      >
        Our Independence High School chapter offers <strong
          style="color: var(--accent-color);"
          >completely free music tutoring</strong
        >
        to students of all ages and skill levels. Whether you're just starting out
        or looking to refine your technique, our experienced student tutors are here
        to help you grow as a musician.
      </p>

      <div
        style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; max-width: 1000px; margin: auto;"
      >
        <FeatureCard icon="fas fa-music" title="Instrument Lessons">
          <p style="color: #fff; line-height: 1.6;">
            Violin, viola, cello, piano, and more
          </p>
        </FeatureCard>
        <FeatureCard icon="fas fa-graduation-cap" title="Music Theory">
          <p style="color: #fff; line-height: 1.6;">
            Learn scales, chords, and composition
          </p>
        </FeatureCard>
        <FeatureCard icon="fas fa-users" title="Ensemble Coaching">
          <p style="color: #fff; line-height: 1.6;">
            Group practice and performance prep
          </p>
        </FeatureCard>
      </div>

      <div style="margin-top: 2rem;">
        <a
          href="/get-tutoring"
          style="display: inline-block; padding: 1rem 2rem; background-color: var(--accent-color); color: #000; text-decoration: none; border-radius: 8px; font-weight: bold; transition: all 0.3s ease;"
        >
          Sign Up for Free Tutoring
        </a>
      </div>
    </section>
  </section>

  <Footer />

  <style>
    /* Responsive design for events section */
    @media screen and (max-width: 768px) {
      .event-card {
        flex-direction: column !important;
      }

      .event-card img {
        width: 100% !important;
        height: 200px !important;
      }
    }
  </style>
</BaseLayout>
